---
import Badge from "./Badge.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  goal: string;
  calories: number;
  macros: { protein: number; carbs: number; fat: number };
  slug: string;
}

const { title, goal, calories, macros, slug } = Astro.props;
const total = macros.protein + macros.carbs + macros.fat;
const pPct = Math.round((macros.protein / total) * 100);
const cPct = Math.round((macros.carbs / total) * 100);
const fPct = 100 - pPct - cPct;
---

<a
  href={`/diets/${slug}`}
  class="group block bg-bg-card border border-border p-7 transition-all duration-500 hover:bg-bg-card-hover hover:border-accent/20 relative overflow-hidden"
>
  {/* Hover glow */}
  <div class="absolute inset-0 bg-gradient-to-br from-accent/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  {/* Faded utensils watermark */}
  <div class="absolute -right-2 -bottom-2 text-text-muted/[0.06] group-hover:text-accent/[0.08] transition-colors duration-500 pointer-events-none" aria-hidden="true">
    <Icon name="lucide:utensils" class="w-20 h-20" />
  </div>

  <div class="relative">
    {/* Top row */}
    <div class="flex items-start justify-between mb-5">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <Icon name="lucide:utensils" class="w-3.5 h-3.5 text-accent" />
          <p class="text-[10px] tracking-[0.2em] uppercase text-text-muted">{goal.replace("-", " ")}</p>
        </div>
        <h3 class="font-display text-xl font-700 tracking-tight text-text-primary group-hover:text-accent transition-colors duration-300">
          {title}
        </h3>
      </div>
      <div class="text-right">
        <div class="flex items-center gap-1.5 text-accent justify-end">
          <Icon name="lucide:flame" class="w-3.5 h-3.5" />
          <span class="font-display text-2xl font-800">{calories}</span>
        </div>
        <p class="text-[10px] tracking-[0.15em] uppercase text-text-muted">cal/day</p>
      </div>
    </div>

    {/* Divider */}
    <div class="h-px bg-border mb-4"></div>

    {/* Mini macro bar */}
    <div class="flex h-1 overflow-hidden bg-border mb-4">
      <div class="bg-accent" style={`width: ${pPct}%`}></div>
      <div class="bg-blue-400" style={`width: ${cPct}%`}></div>
      <div class="bg-amber-400" style={`width: ${fPct}%`}></div>
    </div>

    {/* Macro numbers with icons */}
    <div class="flex gap-6 text-xs">
      <div class="flex items-center gap-1.5">
        <Icon name="lucide:beef" class="w-3 h-3 text-accent" />
        <span class="text-text-muted">Protein</span>
        <span class="text-text-primary font-semibold">{macros.protein}g</span>
      </div>
      <div class="flex items-center gap-1.5">
        <Icon name="lucide:wheat" class="w-3 h-3 text-blue-400" />
        <span class="text-text-muted">Carbs</span>
        <span class="text-text-primary font-semibold">{macros.carbs}g</span>
      </div>
      <div class="flex items-center gap-1.5">
        <Icon name="lucide:droplet" class="w-3 h-3 text-amber-400" />
        <span class="text-text-muted">Fat</span>
        <span class="text-text-primary font-semibold">{macros.fat}g</span>
      </div>
    </div>

    {/* Arrow */}
    <div class="flex justify-end mt-4">
      <span class="text-text-muted group-hover:text-accent group-hover:translate-x-1 transition-all duration-300 text-sm">→</span>
    </div>
  </div>
</a>
