---
interface Props {
  label: string;
  variant?: "default" | "accent";
}

const { label, variant = "default" } = Astro.props;
---

<span
  class:list={[
    "inline-block px-3 py-1 text-[10px] font-semibold tracking-[0.15em] uppercase",
    variant === "accent"
      ? "bg-accent/10 text-accent border border-accent/20"
      : "bg-border/50 text-text-secondary border border-border",
  ]}
>
  {label}
</span>
