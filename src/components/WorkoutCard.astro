---
import Badge from "./Badge.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  category: string;
  targetMuscles: string[];
  difficulty: string;
  duration: string;
  slug: string;
}

const { title, category, targetMuscles, difficulty, duration, slug } = Astro.props;
---

<a
  href={`/workouts/${slug}`}
  class="group block bg-bg-card border border-border p-7 transition-all duration-500 hover:bg-bg-card-hover hover:border-accent/20 relative overflow-hidden"
>
  {/* Hover glow */}
  <div class="absolute inset-0 bg-gradient-to-br from-accent/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  {/* Faded dumbbell watermark */}
  <div class="absolute -right-2 -bottom-2 text-text-muted/[0.06] group-hover:text-accent/[0.08] transition-colors duration-500 pointer-events-none" aria-hidden="true">
    <Icon name="lucide:dumbbell" class="w-20 h-20" />
  </div>

  <div class="relative">
    {/* Top row */}
    <div class="flex items-start justify-between mb-5">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <Icon name="lucide:dumbbell" class="w-3.5 h-3.5 text-accent" />
          <p class="text-[10px] tracking-[0.2em] uppercase text-text-muted">{category}</p>
        </div>
        <h3 class="font-display text-xl font-700 tracking-tight text-text-primary group-hover:text-accent transition-colors duration-300">
          {title}
        </h3>
      </div>
      <div class="flex items-center gap-1.5 text-text-muted">
        <Icon name="lucide:timer" class="w-3.5 h-3.5" />
        <span class="font-display text-sm font-700">{duration}</span>
      </div>
    </div>

    {/* Divider */}
    <div class="h-px bg-border mb-4"></div>

    {/* Tags */}
    <div class="flex flex-wrap gap-2 mb-4">
      <Badge label={difficulty} variant="accent" />
      {targetMuscles.map((muscle) => (
        <Badge label={muscle} />
      ))}
    </div>

    {/* Arrow */}
    <div class="flex justify-end">
      <span class="text-text-muted group-hover:text-accent group-hover:translate-x-1 transition-all duration-300 text-sm">→</span>
    </div>
  </div>
</a>
