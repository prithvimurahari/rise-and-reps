---
import { Icon } from "astro-icon/components";

interface Exercise {
  name: string;
  sets: number;
  reps: string;
  rest: string;
}

interface Props {
  exercises: Exercise[];
}

const { exercises } = Astro.props;
---

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-border text-left">
        <th class="pb-4 pr-6 text-[10px] tracking-[0.2em] uppercase text-text-muted font-semibold">#</th>
        <th class="pb-4 pr-6 text-[10px] tracking-[0.2em] uppercase text-text-muted font-semibold">Exercise</th>
        <th class="pb-4 pr-6 text-[10px] tracking-[0.2em] uppercase text-text-muted font-semibold">Sets</th>
        <th class="pb-4 pr-6 text-[10px] tracking-[0.2em] uppercase text-text-muted font-semibold">Reps</th>
        <th class="pb-4 text-[10px] tracking-[0.2em] uppercase text-text-muted font-semibold">Rest</th>
      </tr>
    </thead>
    <tbody>
      {exercises.map((ex, i) => (
        <tr class="border-b border-border/30 group hover:bg-accent/[0.02] transition-colors duration-300">
          <td class="py-4 pr-6">
            <div class="flex items-center gap-1.5">
              <Icon name="lucide:circle-dot" class="w-3 h-3 text-accent/40 group-hover:text-accent/70 transition-colors duration-300" />
              <span class="font-display font-700 text-text-muted text-xs">{String(i + 1).padStart(2, '0')}</span>
            </div>
          </td>
          <td class="py-4 pr-6 font-medium text-text-primary group-hover:text-accent transition-colors duration-300">
            {ex.name}
          </td>
          <td class="py-4 pr-6 text-text-secondary font-medium">{ex.sets}</td>
          <td class="py-4 pr-6 text-accent font-display font-700">{ex.reps}</td>
          <td class="py-4 text-text-muted flex items-center gap-1.5">
            <Icon name="lucide:timer" class="w-3 h-3 text-text-muted/50" />
            {ex.rest}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
