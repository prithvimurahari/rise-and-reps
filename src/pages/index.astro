---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import WorkoutCard from "../components/WorkoutCard.astro";
import DietCard from "../components/DietCard.astro";
import Badge from "../components/Badge.astro";
import { getCollection } from "astro:content";

const workouts = await getCollection("workouts");
const diets = await getCollection("diets");

const dayOrder = ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday"];
const sortedWorkouts = workouts.sort((a, b) => {
  const aDay = dayOrder.findIndex(d => a.id.startsWith(d));
  const bDay = dayOrder.findIndex(d => b.id.startsWith(d));
  return aDay - bDay;
});
---

<BaseLayout title="Home">
  <Hero />

  {/* Motivational marquee */}
  <div class="border-t border-b border-border py-5 overflow-hidden">
    <div class="flex whitespace-nowrap" style="animation: marquee 35s linear infinite;">
      {Array.from({ length: 8 }).map(() => (
        <span class="font-display text-sm md:text-base font-700 tracking-[0.2em] uppercase text-text-secondary/40 mx-8">
          NO EXCUSES <span class="text-accent/50 mx-3">✦</span> EARN YOUR REST <span class="text-accent/50 mx-3">✦</span> ONE MORE REP <span class="text-accent/50 mx-3">✦</span> TRUST THE PROCESS <span class="text-accent/50 mx-3">✦</span> OUTWORK YESTERDAY <span class="text-accent/50 mx-3">✦</span>
        </span>
      ))}
    </div>
  </div>

  {/* Weekly Training Section */}
  <section class="px-6 md:px-10 py-24 md:py-32 scroll-reveal">
    <div class="max-w-7xl mx-auto">
      {/* Section header */}
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <div class="md:col-span-8">
          <div class="flex items-center gap-4 mb-4">
            <span class="font-display text-6xl md:text-8xl font-800 text-text-muted/10 leading-none">01</span>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <h2 class="font-display text-4xl md:text-6xl font-800 tracking-tight leading-[0.95]">
            Weekly<br/>
            <span class="text-accent">Training Split</span>
          </h2>
        </div>
        <div class="md:col-span-4 flex flex-col justify-end">
          <p class="text-text-secondary text-sm leading-relaxed mb-4">
            6 days of structured training, each targeting different muscle groups. Sunday is for recovery. Every session designed for progressive overload.
          </p>
          <a href="/workouts" class="group text-[11px] tracking-[0.2em] uppercase text-accent hover:text-accent-hover transition-colors duration-300 flex items-center gap-2 w-fit">
            All workouts
            <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
        </div>
      </div>

      {/* Day cards grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
        {sortedWorkouts.map((workout) => (
          <WorkoutCard
            title={workout.data.title}
            category={workout.data.category}
            targetMuscles={workout.data.targetMuscles}
            difficulty={workout.data.difficulty}
            duration={workout.data.duration}
            slug={workout.id}
          />
        ))}
        {/* Sunday rest card */}
        <div class="bg-bg-card p-7 flex flex-col justify-center items-center text-center border border-transparent">
          <span class="font-display text-4xl font-800 text-text-muted/15 mb-3">💤</span>
          <p class="text-[10px] tracking-[0.2em] uppercase text-text-muted mb-2">rest day</p>
          <h3 class="font-display text-xl font-700 tracking-tight text-text-muted">Sunday</h3>
          <p class="text-text-muted text-xs mt-3 max-w-[200px]">Recover. Sleep. Eat. Come back stronger Monday.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Quote / manifesto break */}
  <section class="px-6 md:px-10 py-20 md:py-28 border-t border-border relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-accent/[0.02] via-transparent to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto relative">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-6 h-px bg-accent"></div>
          <p class="text-[10px] tracking-[0.3em] uppercase text-accent">Manifesto</p>
        </div>
        <blockquote class="font-display text-2xl md:text-4xl font-700 tracking-tight leading-[1.15] text-text-primary">
          "The body achieves what the mind believes. Track everything. Trust the process.
          <span class="text-accent">Let the data speak.</span>"
        </blockquote>
        <p class="text-text-muted text-sm mt-6">— Prithvi</p>
      </div>
    </div>
  </section>

  {/* Diet Section */}
  <section class="px-6 md:px-10 py-24 md:py-32 border-t border-border scroll-reveal">
    <div class="max-w-7xl mx-auto">
      {/* Section header */}
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
        <div class="md:col-span-4 md:order-2 flex flex-col justify-end">
          <p class="text-text-secondary text-sm leading-relaxed mb-4">
            Macro-optimized meal plans for every goal. 7-day diet charts with every calorie and meal structured for results.
          </p>
          <a href="/diets" class="group text-[11px] tracking-[0.2em] uppercase text-accent hover:text-accent-hover transition-colors duration-300 flex items-center gap-2 w-fit">
            All diet plans
            <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
        </div>
        <div class="md:col-span-8 md:order-1">
          <div class="flex items-center gap-4 mb-4">
            <span class="font-display text-6xl md:text-8xl font-800 text-text-muted/10 leading-none">02</span>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <h2 class="font-display text-4xl md:text-6xl font-800 tracking-tight leading-[0.95]">
            Diet<br/>
            <span class="text-accent">Plans</span>
          </h2>
        </div>
      </div>

      {/* Diet cards */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
        {diets.map((diet) => (
          <DietCard
            title={diet.data.title}
            goal={diet.data.goal}
            calories={diet.data.calories}
            macros={diet.data.macros}
            slug={diet.id}
          />
        ))}
      </div>
    </div>
  </section>

  {/* Philosophy strip */}
  <section class="px-6 md:px-10 py-20 md:py-28 border-t border-border bg-bg-secondary">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-4 mb-12">
        <span class="font-display text-6xl md:text-8xl font-800 text-text-muted/10 leading-none">03</span>
        <div class="h-px flex-1 bg-border"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
        <div class="bg-bg-primary p-8 md:p-10 group hover:bg-bg-card transition-colors duration-500">
          <span class="font-display text-5xl font-800 text-accent/20 group-hover:text-accent/40 transition-colors duration-500 block mb-6">01</span>
          <h3 class="font-display text-lg font-700 tracking-tight text-text-primary mb-3">Consistency over intensity</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Show up every day. The best program is the one you follow without excuses.</p>
        </div>
        <div class="bg-bg-primary p-8 md:p-10 group hover:bg-bg-card transition-colors duration-500">
          <span class="font-display text-5xl font-800 text-accent/20 group-hover:text-accent/40 transition-colors duration-500 block mb-6">02</span>
          <h3 class="font-display text-lg font-700 tracking-tight text-text-primary mb-3">Progressive overload is law</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Everything else is preference. Lift more, do more, be more than yesterday.</p>
        </div>
        <div class="bg-bg-primary p-8 md:p-10 group hover:bg-bg-card transition-colors duration-500">
          <span class="font-display text-5xl font-800 text-accent/20 group-hover:text-accent/40 transition-colors duration-500 block mb-6">03</span>
          <h3 class="font-display text-lg font-700 tracking-tight text-text-primary mb-3">Diet is the foundation</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Training is the trigger, food is the builder. You can't out-train a bad diet.</p>
        </div>
      </div>
    </div>
  </section>

  {/* CTA section */}
  <section class="px-6 md:px-10 py-24 md:py-32 border-t border-border relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-accent/[0.03] via-transparent to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto text-center relative">
      <p class="text-[10px] tracking-[0.3em] uppercase text-text-muted mb-6">Start here</p>
      <h2 class="font-display text-3xl md:text-5xl font-800 tracking-tight mb-4">
        Ready to <span class="text-accent">train</span>?
      </h2>
      <p class="text-text-secondary text-sm md:text-base max-w-md mx-auto mb-10">
        Pick a day, follow the program, fuel with the right diet.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/workouts"
          class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent text-bg-primary font-semibold text-sm tracking-wide uppercase transition-all duration-300 hover:bg-accent-hover"
        >
          Browse Workouts
          <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-border text-text-secondary font-semibold text-sm tracking-wide uppercase transition-all duration-300 hover:border-accent hover:text-accent"
        >
          About Prithvi
        </a>
      </div>
    </div>
  </section>

  {/* Bottom marquee */}
  <div class="border-t border-border py-4 overflow-hidden">
    <div class="flex whitespace-nowrap" style="animation: marquee 25s linear infinite reverse;">
      {Array.from({ length: 10 }).map(() => (
        <span class="font-display text-xl font-800 text-text-muted/[0.06] mx-8 tracking-tight">
          PRITHVI <span class="text-accent/10">·</span> RISE & REPS <span class="text-accent/10">·</span>
        </span>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-fade-up');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  reveals.forEach(el => {
    el.style.opacity = '0';
    observer.observe(el);
  });
</script>
