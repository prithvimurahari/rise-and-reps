---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DietCard from "../../components/DietCard.astro";
import { getCollection } from "astro:content";

const diets = await getCollection("diets");
---

<BaseLayout title="Diet Plans" description="Browse all diet plans">
  <section class="px-6 md:px-10 py-16 md:py-24">
    <div class="max-w-7xl mx-auto">
      <div class="mb-14 animate-fade-up">
        <p class="text-[10px] tracking-[0.3em] uppercase text-text-muted mb-3">Meal Plans</p>
        <h1 class="font-display text-4xl md:text-6xl font-extrabold tracking-tight mb-3">Diet Plans</h1>
        <div class="h-px bg-accent w-16 animate-reveal-line delay-2"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border animate-fade-up delay-3">
        {diets.map((diet) => (
          <DietCard
            title={diet.data.title}
            goal={diet.data.goal}
            calories={diet.data.calories}
            macros={diet.data.macros}
            slug={diet.id}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
