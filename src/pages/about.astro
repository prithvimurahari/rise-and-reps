---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Prithvi — Rise & Reps">
  <section class="px-6 md:px-10 py-16 md:py-24">
    <div class="max-w-3xl mx-auto">
      <div class="animate-fade-up">
        <p class="text-[10px] tracking-[0.3em] uppercase text-text-muted mb-3">The Person</p>
        <h1 class="font-display text-4xl md:text-6xl font-800 tracking-tight mb-3">About</h1>
        <div class="h-px bg-accent w-16 animate-reveal-line delay-2"></div>
      </div>

      <div class="mt-14 space-y-8 animate-fade-up delay-3">
        <p class="text-text-secondary text-lg leading-relaxed">
          Welcome to <span class="text-accent font-display font-700">PRITHVI</span> — my personal space for organizing and sharing the workout routines and diet plans that fuel my fitness journey.
        </p>

        <p class="text-text-secondary leading-relaxed">
          I built this site to keep all my training knowledge in one place. Whether you're looking for a solid push/pull split, a bulking meal plan, or just some inspiration to get moving — you'll find it here.
        </p>

        <p class="text-text-secondary leading-relaxed">
          Every routine has been tested in the gym. Every diet plan has been lived. This isn't theory — it's practice.
        </p>
      </div>

      <div class="h-px bg-border my-16 animate-reveal-line delay-4"></div>

      <div class="animate-fade-up delay-5">
        <p class="text-[10px] tracking-[0.3em] uppercase text-text-muted mb-8">Philosophy</p>

        <div class="space-y-0">
          <div class="border-b border-border py-8 first:pt-0 flex items-start gap-8 group">
            <span class="font-display text-4xl md:text-5xl font-800 text-text-muted/20 group-hover:text-accent/30 transition-colors duration-500 leading-none">01</span>
            <div>
              <h3 class="font-display text-xl font-700 tracking-tight text-text-primary mb-2">Consistency over intensity</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Show up every day. The best program is the one you actually follow.</p>
            </div>
          </div>

          <div class="border-b border-border py-8 flex items-start gap-8 group">
            <span class="font-display text-4xl md:text-5xl font-800 text-text-muted/20 group-hover:text-accent/30 transition-colors duration-500 leading-none">02</span>
            <div>
              <h3 class="font-display text-xl font-700 tracking-tight text-text-primary mb-2">Progressive overload is law</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Everything else is preference. Lift more, do more, be more.</p>
            </div>
          </div>

          <div class="py-8 flex items-start gap-8 group">
            <span class="font-display text-4xl md:text-5xl font-800 text-text-muted/20 group-hover:text-accent/30 transition-colors duration-500 leading-none">03</span>
            <div>
              <h3 class="font-display text-xl font-700 tracking-tight text-text-primary mb-2">Nutrition is the foundation</h3>
              <p class="text-text-secondary text-sm leading-relaxed">Training is the trigger. Food is the builder. You can't out-train a bad diet.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
